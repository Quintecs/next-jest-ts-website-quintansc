{
  "root": true,
  "extends": ["eslint:recommended"],
  "plugins": ["testing-library"],
  "rules": {
    "@next/next/google-font-preconnect": "on"
  },
  "overrides": [
    {
      "files": [
        "**/__tests__/**/*.[jt]s?(x)",
        "**/?(*.)+(spec|test).[jt]s?(x)"
      ],
      "extends": ["plugin:testing-library/react"]
    }
  ]
}
